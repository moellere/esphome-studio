{
  "schema_version": "0.1",
  "id": "rc522",
  "name": "RC522 RFID reader station",
  "description": "ESP8266 D1 Mini with an MFRC522 RFID reader on SPI, plus a NeoPixel status LED, a piezo buzzer driven by RTTTL, and a hardware button.",
  "created_at": "2021-05-01T00:00:00Z",
  "updated_at": "2026-05-04T00:00:00Z",

  "board": {
    "library_id": "wemos-d1-mini",
    "mcu": "esp8266",
    "framework": "arduino"
  },

  "power": {
    "supply": "usb-5v",
    "rail_voltage_v": 5.0,
    "regulator": "onboard-rt9013",
    "budget_ma": 500
  },

  "requirements": [
    { "id": "r1", "kind": "capability", "text": "scan RFID tags via MFRC522 over SPI" },
    { "id": "r2", "kind": "capability", "text": "feedback on tag scan: NeoPixel flash + RTTTL beep, both maskable from HA" },
    { "id": "r3", "kind": "capability", "text": "physical button for manual interaction" }
  ],

  "components": [
    { "id": "reader", "library_id": "rc522", "label": "RFID Reader", "role": "rfid_reader",
      "params": {
        "update_interval": "2s",
        "on_tag": {
          "then": [
            { "homeassistant.event": { "event": "esphome.tag_scanned",
                                        "data": { "tag_id": "!lambda return x;" } } },
            { "if": { "condition": { "switch.is_on": "buzzer_enabled" },
                      "then": [ { "rtttl.play": "success:d=24,o=5,b=100:c,g,b" } ] } },
            { "if": { "condition": { "switch.is_on": "led_enabled" },
                      "then": [
                        { "light.turn_on": { "id": "activity_led",
                                             "brightness": "100%",
                                             "red": "0%", "green": "100%", "blue": "0%",
                                             "flash_length": "500ms" } }
                      ] } }
          ]
        }
      }
    },

    { "id": "activity_led", "library_id": "ws2812b", "label": "RC522 Reader LED",
      "params": { "variant": "400KBPS", "method": "BIT_BANG", "type": "RGB", "num_leds": 1 } },

    { "id": "rfid_button", "library_id": "gpio_input", "label": "RC522 Reader Button",
      "params": { "filters": [ { "invert": null } ] } }
  ],

  "buses": [
    { "id": "spi0", "type": "spi", "clk": "D5", "miso": "D6", "mosi": "D7" }
  ],

  "connections": [
    { "component_id": "reader", "pin_role": "VCC",   "target": { "kind": "rail", "rail": "3V3" } },
    { "component_id": "reader", "pin_role": "GND",   "target": { "kind": "rail", "rail": "GND" } },
    { "component_id": "reader", "pin_role": "SCK",   "target": { "kind": "bus",  "bus_id": "spi0" } },
    { "component_id": "reader", "pin_role": "MISO",  "target": { "kind": "bus",  "bus_id": "spi0" } },
    { "component_id": "reader", "pin_role": "MOSI",  "target": { "kind": "bus",  "bus_id": "spi0" } },
    { "component_id": "reader", "pin_role": "CS",    "target": { "kind": "gpio", "pin": "D8" } },
    { "component_id": "reader", "pin_role": "RESET", "target": { "kind": "gpio", "pin": "D4" } },

    { "component_id": "activity_led", "pin_role": "VCC", "target": { "kind": "rail", "rail": "5V" } },
    { "component_id": "activity_led", "pin_role": "GND", "target": { "kind": "rail", "rail": "GND" } },
    { "component_id": "activity_led", "pin_role": "DIN", "target": { "kind": "gpio", "pin": "D3" } },

    { "component_id": "rfid_button", "pin_role": "IN",  "target": { "kind": "gpio", "pin": "D1" } }
  ],

  "passives": [
    { "id": "c1", "kind": "capacitor", "value": "100nF",
      "between": ["reader.VCC", "GND"], "purpose": "decoupling reader" },
    { "id": "c2", "kind": "capacitor", "value": "100nF",
      "between": ["activity_led.VCC", "GND"], "purpose": "decoupling neopixel" }
  ],

  "warnings": [
    { "level": "info", "code": "buzzer_in_extras",
      "text": "Piezo buzzer (esp8266_pwm output) and RTTTL block live in esphome_extras until a buzzer/rtttl library entry lands." }
  ],

  "esphome_extras": {
    "logger": { "baud_rate": 9600 },
    "esphome": {
      "on_boot": {
        "priority": -10,
        "then": [
          { "wait_until": { "api.connected": null } },
          { "logger.log": "API is connected!" },
          { "rtttl.play": "success:d=24,o=5,b=100:c,g,b" }
        ]
      }
    },
    "switch": [
      { "platform": "restart",  "name": "RFID Reader Restart", "id": "reboot" },
      { "platform": "template", "name": "RC522 Reader Buzzer Enabled",
        "id": "buzzer_enabled", "icon": "mdi:volume-high",         "optimistic": true },
      { "platform": "template", "name": "RC522 Reader LED enabled",
        "id": "led_enabled",    "icon": "mdi:alarm-light-outline", "optimistic": true }
    ],
    "api": {
      "services": [
        { "service": "rfidreader_tag_ok", "then": [ { "rtttl.play": "beep:d=16,o=5,b=100:b" } ] },
        { "service": "rfidreader_tag_ko", "then": [ { "rtttl.play": "beep:d=8,o=5,b=100:b"  } ] },
        { "service": "play_rtttl",
          "variables": { "song_str": "string" },
          "then": [ { "rtttl.play": "!lambda return song_str;" } ] }
      ]
    },
    "output": [
      { "platform": "esp8266_pwm", "pin": "D2", "id": "buzzer" }
    ],
    "rtttl": { "output": "buzzer" }
  },

  "fleet": {
    "device_name": "rc522",
    "tags": ["indoor", "rfid"],
    "secrets_ref": {
      "wifi_ssid": "!secret wifi_ssid",
      "wifi_password": "!secret wifi_password",
      "api_key": "!secret api_key"
    }
  }
}
