{
  "schema_version": "0.1",
  "id": "securitypanel",
  "name": "Whole-house door/window/motion security panel",
  "description": "ESP8266 D1 Mini reads 12 contact + motion sensors through an MCP23017 over I2C and drives a piezo buzzer (RTTTL) on D7. Each sensor pin is its own gpio_input component bound to an expander_pin connection.",
  "created_at": "2021-04-01T00:00:00Z",
  "updated_at": "2026-05-03T12:00:00Z",

  "board": {
    "library_id": "wemos-d1-mini",
    "mcu": "esp8266",
    "framework": "arduino"
  },

  "power": {
    "supply": "usb-5v",
    "rail_voltage_v": 5.0,
    "regulator": "onboard-rt9013",
    "budget_ma": 500
  },

  "requirements": [
    { "id": "r1", "kind": "capability",  "text": "publish 11 door/window/motion binary_sensors to Home Assistant" },
    { "id": "r2", "kind": "capability",  "text": "play short RTTTL tones on sensor events and a longer one on API connect" },
    { "id": "r3", "kind": "capability",  "text": "drive a security siren as a switch" },
    { "id": "r4", "kind": "constraint",  "text": "16 GPIOs needed; expand via MCP23017" }
  ],

  "components": [
    { "id": "mcp_hub",        "library_id": "mcp23017", "label": "Sensor IO expander", "role": "io_expander",
      "params": { "address": "0x20" } },

    { "id": "mbr_door",         "library_id": "gpio_input", "label": "MBR Door/Window",
      "params": { "device_class": "door",
                  "on_press": [ { "rtttl.play": "short:d=4,o=5,b=100:16e6,16e6" } ] } },
    { "id": "living_room_doors","library_id": "gpio_input", "label": "Living Room Doors",
      "params": { "device_class": "door",
                  "on_press": [ { "rtttl.play": "short:d=4,o=5,b=100:16e6,16e6" } ] } },
    { "id": "office_dining_windows","library_id": "gpio_input", "label": "Office/Dining Room Windows",
      "params": { "device_class": "window",
                  "on_press": [ { "rtttl.play": "short:d=4,o=5,b=100:16e6,16e6" } ] } },
    { "id": "pin_a7",           "library_id": "gpio_input", "label": "Pin A7",
      "params": { "on_press": [ { "rtttl.play": "short:d=4,o=5,b=100:16e6,16e6" } ] } },
    { "id": "kitchen_door",     "library_id": "gpio_input", "label": "Kitchen Door",
      "params": { "device_class": "door",
                  "on_press": [ { "rtttl.play": "short:d=4,o=5,b=100:16e6,16e6" } ] } },
    { "id": "kitchen_window",   "library_id": "gpio_input", "label": "Kitchen Window",
      "params": { "device_class": "window",
                  "on_press": [ { "rtttl.play": "short:d=4,o=5,b=100:16e6,16e6" } ] } },
    { "id": "living_room_motion","library_id": "gpio_input", "label": "Living Room Motion",
      "params": { "device_class": "motion" } },
    { "id": "garage_hall_door", "library_id": "gpio_input", "label": "Garage Hall Door",
      "params": { "device_class": "door",
                  "on_press": [ { "rtttl.play": "short:d=4,o=5,b=100:16e6,16e6" } ] } },
    { "id": "front_door",       "library_id": "gpio_input", "label": "Front Door",
      "params": { "device_class": "door",
                  "on_press": [ { "rtttl.play": "short:d=4,o=5,b=100:16e6,16e6" } ] } },
    { "id": "laundry_room",     "library_id": "gpio_input", "label": "Laundry Room",
      "params": { "device_class": "door",
                  "on_press": [ { "rtttl.play": "short:d=4,o=5,b=100:16e6,16e6" } ] } },
    { "id": "pin_b6",           "library_id": "gpio_input", "label": "Pin B6",
      "params": { "on_press": [ { "rtttl.play": "short:d=4,o=5,b=100:16e6,16e6" } ] } },
    { "id": "pin_b7",           "library_id": "gpio_input", "label": "Pin B7",
      "params": { "on_press": [ { "rtttl.play": "short:d=4,o=5,b=100:16e6,16e6" } ] } },

    { "id": "security_siren",   "library_id": "gpio_output", "label": "Security Siren" }
  ],

  "buses": [
    { "id": "i2c0", "type": "i2c", "frequency_hz": 100000, "sda": "D2", "scl": "D1" }
  ],

  "connections": [
    { "component_id": "mcp_hub", "pin_role": "VCC", "target": { "kind": "rail", "rail": "3V3" } },
    { "component_id": "mcp_hub", "pin_role": "GND", "target": { "kind": "rail", "rail": "GND" } },
    { "component_id": "mcp_hub", "pin_role": "SDA", "target": { "kind": "bus",  "bus_id": "i2c0" } },
    { "component_id": "mcp_hub", "pin_role": "SCL", "target": { "kind": "bus",  "bus_id": "i2c0" } },

    { "component_id": "mbr_door",            "pin_role": "IN", "target": { "kind": "expander_pin", "expander_id": "mcp_hub", "number": 4,  "mode": "INPUT", "inverted": true } },
    { "component_id": "living_room_doors",   "pin_role": "IN", "target": { "kind": "expander_pin", "expander_id": "mcp_hub", "number": 5,  "mode": "INPUT", "inverted": true } },
    { "component_id": "office_dining_windows","pin_role":"IN", "target": { "kind": "expander_pin", "expander_id": "mcp_hub", "number": 6,  "mode": "INPUT", "inverted": true } },
    { "component_id": "pin_a7",              "pin_role": "IN", "target": { "kind": "expander_pin", "expander_id": "mcp_hub", "number": 7,  "mode": "INPUT", "inverted": true } },
    { "component_id": "kitchen_door",        "pin_role": "IN", "target": { "kind": "expander_pin", "expander_id": "mcp_hub", "number": 8,  "mode": "INPUT", "inverted": true } },
    { "component_id": "kitchen_window",      "pin_role": "IN", "target": { "kind": "expander_pin", "expander_id": "mcp_hub", "number": 9,  "mode": "INPUT", "inverted": true } },
    { "component_id": "living_room_motion",  "pin_role": "IN", "target": { "kind": "expander_pin", "expander_id": "mcp_hub", "number": 10, "mode": "INPUT", "inverted": true } },
    { "component_id": "garage_hall_door",    "pin_role": "IN", "target": { "kind": "expander_pin", "expander_id": "mcp_hub", "number": 11, "mode": "INPUT", "inverted": true } },
    { "component_id": "front_door",          "pin_role": "IN", "target": { "kind": "expander_pin", "expander_id": "mcp_hub", "number": 12, "mode": "INPUT", "inverted": true } },
    { "component_id": "laundry_room",        "pin_role": "IN", "target": { "kind": "expander_pin", "expander_id": "mcp_hub", "number": 13, "mode": "INPUT", "inverted": true } },
    { "component_id": "pin_b6",              "pin_role": "IN", "target": { "kind": "expander_pin", "expander_id": "mcp_hub", "number": 14, "mode": "INPUT", "inverted": true } },
    { "component_id": "pin_b7",              "pin_role": "IN", "target": { "kind": "expander_pin", "expander_id": "mcp_hub", "number": 15, "mode": "INPUT", "inverted": true } },

    { "component_id": "security_siren",      "pin_role": "OUT","target": { "kind": "expander_pin", "expander_id": "mcp_hub", "number": 3,  "mode": "OUTPUT", "inverted": true } }
  ],

  "passives": [
    { "id": "c1", "kind": "capacitor", "value": "100nF",
      "between": ["mcp_hub.VCC", "GND"], "purpose": "decoupling mcp23017" },
    { "id": "r1", "kind": "resistor",  "value": "4.7k",
      "between": ["i2c0.SDA", "3V3"],  "purpose": "I2C pull-up" },
    { "id": "r2", "kind": "resistor",  "value": "4.7k",
      "between": ["i2c0.SCL", "3V3"],  "purpose": "I2C pull-up" }
  ],

  "warnings": [],

  "esphome_extras": {
    "logger": {},
    "esphome": {
      "on_boot": {
        "priority": -10,
        "then": [
          { "wait_until": { "api.connected": null } },
          { "logger.log": "API is connected!" },
          { "rtttl.play": "success:d=24,o=5,b=100:c,g,b" }
        ]
      }
    },
    "time": [
      { "platform": "homeassistant", "id": "homeassistant_time" }
    ],
    "output": [
      { "platform": "esp8266_pwm", "pin": "D7", "id": "rtttl_out" }
    ],
    "rtttl": {
      "output": "rtttl_out",
      "on_finished_playback": [ { "logger.log": "RTTTL ended!" } ]
    },
    "api": {
      "services": [
        {
          "service": "play_rtttl",
          "variables": { "song_str": "string" },
          "then": [ { "rtttl.play": { "rtttl": "!lambda return song_str;" } } ]
        }
      ]
    },
    "switch": [
      { "platform": "restart", "name": "Security Panel Restart" }
    ]
  },

  "fleet": {
    "device_name": "securitypanel",
    "tags": ["indoor", "security"],
    "secrets_ref": {
      "wifi_ssid": "!secret wifi_ssid",
      "wifi_password": "!secret wifi_password",
      "api_key": "!secret api_key"
    }
  }
}
