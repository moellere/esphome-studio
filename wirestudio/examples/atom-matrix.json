{
  "schema_version": "0.1",
  "id": "atom-matrix",
  "name": "M5Stack Atom Matrix (5x5 LED + button)",
  "description": "M5Stack Atom Matrix driving its onboard 5x5 (25-LED) SK6812 RGB matrix on GPIO27 via the ESP32 RMT peripheral, plus the programmable button on GPIO39 hidden under the matrix.",
  "created_at": "2026-05-16T00:00:00Z",
  "updated_at": "2026-05-16T00:00:00Z",

  "board": {
    "library_id": "m5stack-atom-matrix",
    "mcu": "esp32",
    "framework": "arduino"
  },

  "power": {
    "supply": "usb-5v",
    "rail_voltage_v": 5.0,
    "regulator": "onboard",
    "budget_ma": 1500
  },

  "requirements": [
    { "id": "r1", "kind": "capability", "text": "drive the onboard 5x5 RGB LED matrix" },
    { "id": "r2", "kind": "capability", "text": "read the programmable button" }
  ],

  "components": [
    {
      "id": "matrix",
      "library_id": "esp32_rmt_led_strip",
      "label": "LED matrix",
      "params": { "rgb_order": "GRB", "num_leds": 25, "chipset": "SK6812" }
    },
    {
      "id": "btn",
      "library_id": "gpio_input",
      "label": "Button"
    }
  ],

  "buses": [],

  "connections": [
    { "component_id": "matrix", "pin_role": "VCC", "target": { "kind": "rail", "rail": "5V" } },
    { "component_id": "matrix", "pin_role": "GND", "target": { "kind": "rail", "rail": "GND" } },
    { "component_id": "matrix", "pin_role": "DIN", "target": { "kind": "gpio", "pin": "GPIO27" } },
    { "component_id": "btn",    "pin_role": "IN",  "target": { "kind": "gpio", "pin": "GPIO39" } }
  ],

  "passives": [],

  "warnings": [],

  "esphome_extras": {
    "captive_portal": {},
    "logger": {}
  },

  "fleet": {
    "device_name": "atom-matrix",
    "tags": ["m5stack", "atom"],
    "secrets_ref": {
      "wifi_ssid": "!secret wifi_ssid",
      "wifi_password": "!secret wifi_password",
      "api_key": "!secret api_key"
    }
  }
}
