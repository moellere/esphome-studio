{
  "schema_version": "0.1",
  "id": "wasserpir",
  "name": "Wasserstein PIR motion sensor",
  "description": "ESP8266 D1 Mini with a single PIR on D2. Sends motion to Home Assistant; reboots itself nightly.",
  "created_at": "2020-06-01T00:00:00Z",
  "updated_at": "2026-05-03T12:00:00Z",

  "board": {
    "library_id": "wemos-d1-mini",
    "mcu": "esp8266",
    "framework": "arduino"
  },

  "power": {
    "supply": "usb-5v",
    "rail_voltage_v": 5.0,
    "regulator": "onboard-rt9013",
    "budget_ma": 500
  },

  "requirements": [
    { "id": "r1", "kind": "capability",  "text": "report motion as a binary_sensor" },
    { "id": "r2", "kind": "constraint",  "text": "reboot daily to recover from drift" }
  ],

  "components": [
    {
      "id": "pir1",
      "library_id": "hc-sr501",
      "label": "Wasserstein Motion",
      "role": "motion_sensor",
      "params": {
        "filters": [ { "delayed_on": "100ms" } ]
      }
    }
  ],

  "buses": [],

  "connections": [
    { "component_id": "pir1", "pin_role": "VCC", "target": { "kind": "rail", "rail": "5V" } },
    { "component_id": "pir1", "pin_role": "GND", "target": { "kind": "rail", "rail": "GND" } },
    { "component_id": "pir1", "pin_role": "OUT", "target": { "kind": "gpio", "pin": "D2" } }
  ],

  "passives": [],
  "warnings": [],

  "esphome_extras": {
    "logger": {},
    "switch": [
      { "platform": "restart", "name": "Wasserstein Motion Restart", "id": "reboot" }
    ],
    "time": [
      {
        "platform": "homeassistant",
        "id": "time1",
        "timezone": "America/Chicago",
        "on_time": [
          {
            "seconds": 0, "minutes": 30, "hours": 3,
            "then": [ { "switch.toggle": "reboot" } ]
          }
        ]
      }
    ]
  },

  "fleet": {
    "device_name": "wasserpir",
    "tags": ["indoor", "motion"],
    "secrets_ref": {
      "wifi_ssid": "!secret wifi_ssid",
      "wifi_password": "!secret wifi_password",
      "api_key": "!secret api_key"
    }
  }
}
