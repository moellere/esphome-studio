{
  "schema_version": "0.1",
  "id": "bluemotion",
  "name": "Blue motion sensor with NeoPixel feedback",
  "description": "ESP8266 D1 Mini, single PIR on GPIO4, single WS2812B on GPIO14. Motion lights the LED; LED also blinks on boot.",
  "created_at": "2020-08-01T00:00:00Z",
  "updated_at": "2026-05-03T12:00:00Z",

  "board": {
    "library_id": "wemos-d1-mini",
    "mcu": "esp8266",
    "framework": "arduino"
  },

  "power": {
    "supply": "usb-5v",
    "rail_voltage_v": 5.0,
    "regulator": "onboard-rt9013",
    "budget_ma": 500
  },

  "requirements": [
    { "id": "r1", "kind": "capability",  "text": "report motion as a binary_sensor" },
    { "id": "r2", "kind": "capability",  "text": "single-LED visual feedback on motion + boot" }
  ],

  "components": [
    {
      "id": "pir1",
      "library_id": "hc-sr501",
      "label": "Blue Motion",
      "role": "motion_sensor",
      "params": {
        "filters":    [ { "delayed_on": "40ms" } ],
        "on_press":   [ { "then": [ { "light.turn_on":  { "id": "led1", "brightness": 1.0 } } ] } ],
        "on_release": [ { "then": [ { "light.turn_off": { "id": "led1" } } ] } ]
      }
    },
    {
      "id": "led1",
      "library_id": "ws2812b",
      "label": "LED 1",
      "role": "indicator",
      "params": {
        "variant": "400KBPS",
        "method":  "BIT_BANG",
        "type":    "RGB",
        "num_leds": 1
      }
    }
  ],

  "buses": [],

  "connections": [
    { "component_id": "pir1", "pin_role": "VCC", "target": { "kind": "rail", "rail": "5V" } },
    { "component_id": "pir1", "pin_role": "GND", "target": { "kind": "rail", "rail": "GND" } },
    { "component_id": "pir1", "pin_role": "OUT", "target": { "kind": "gpio", "pin": "GPIO4" } },

    { "component_id": "led1", "pin_role": "VCC", "target": { "kind": "rail", "rail": "5V" } },
    { "component_id": "led1", "pin_role": "GND", "target": { "kind": "rail", "rail": "GND" } },
    { "component_id": "led1", "pin_role": "DIN", "target": { "kind": "gpio", "pin": "GPIO14" } }
  ],

  "passives": [
    { "id": "c1", "kind": "capacitor", "value": "100nF",
      "between": ["led1.VCC", "GND"], "purpose": "decoupling led1" }
  ],

  "warnings": [],

  "esphome_extras": {
    "logger": {},
    "esphome": {
      "on_boot": {
        "then": [
          { "light.turn_on": "led1" },
          { "delay": "2s" },
          { "light.turn_off": "led1" }
        ]
      }
    },
    "switch": [
      { "platform": "restart", "name": "Blue Motion Restart" }
    ]
  },

  "fleet": {
    "device_name": "bluemotion1",
    "tags": ["indoor", "motion"],
    "secrets_ref": {
      "wifi_ssid": "!secret wifi_ssid",
      "wifi_password": "!secret wifi_password",
      "api_key": "!secret api_key"
    }
  }
}
