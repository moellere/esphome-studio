{
  "schema_version": "0.1",
  "id": "esp32-audio",
  "name": "Garage I2S audio + ST7789 dashboard",
  "description": "ESP32 NodeMCU-32S, Arduino framework. MAX98357A I2S DAC drives a Class-D speaker; ST7789V SPI display shows a clock + status. Hardware mute and backlight switches.",
  "created_at": "2022-09-01T00:00:00Z",
  "updated_at": "2026-05-05T00:00:00Z",

  "board": {
    "library_id": "nodemcu-32s",
    "mcu": "esp32",
    "framework": "arduino"
  },

  "power": {
    "supply": "usb-5v",
    "rail_voltage_v": 5.0,
    "regulator": "onboard-ams1117",
    "budget_ma": 2000
  },

  "requirements": [
    { "id": "r1", "kind": "capability", "text": "act as a media_player streaming I2S audio to an external Class-D amp" },
    { "id": "r2", "kind": "capability", "text": "render a clock + status on a 240x320 ST7789 dashboard" },
    { "id": "r3", "kind": "capability", "text": "physical mute switch + backlight switch" },
    { "id": "r4", "kind": "constraint",  "text": "Arduino framework (max98357a media_player is arduino-only in upstream ESPHome; revisit when esp-idf adds the platform)" }
  ],

  "components": [
    { "id": "amp", "library_id": "max98357a", "label": "Esp32 Audio Media Player",
      "params": { "mode": "stereo" } },

    { "id": "screen", "library_id": "st7789", "label": "Esp32 Audio Display",
      "params": {
        "rotation": 270,
        "model": "Custom",
        "width": 240,
        "height": 320,
        "offset_width": 0,
        "offset_height": 0,
        "lambda_": "it.rectangle(0,  0, it.get_width(), it.get_height(), id(my_blue));\nit.rectangle(0, 20, it.get_width(), it.get_height(), id(my_blue));\nit.strftime((240 / 2), (140 / 4) * 1 + 5, id(arial_12), id(my_gray), TextAlign::CENTER, \"%Y-%m-%d\", id(esptime).now());\nit.strftime((240 / 2), (140 / 4) * 2 + 5, id(arial_24), id(my_gray), TextAlign::CENTER, \"%H:%M:%S\", id(esptime).now());\nit.print(5, 5, id(arial_12), id(my_yellow), TextAlign::TOP_LEFT, \"ESPHome\");\n"
      }
    },

    { "id": "mute",      "library_id": "gpio_output", "label": "Esp32 Audio Mute",
      "params": { "icon": "mdi:volume-mute" } },
    { "id": "backlight", "library_id": "gpio_output", "label": "Backlight" }
  ],

  "buses": [
    { "id": "spi0", "type": "spi", "clk": "GPIO18", "mosi": "GPIO23" },
    { "id": "i2s0", "type": "i2s", "lrclk": "GPIO33", "bclk": "GPIO25" }
  ],

  "connections": [
    { "component_id": "amp", "pin_role": "VCC",   "target": { "kind": "rail", "rail": "5V" } },
    { "component_id": "amp", "pin_role": "GND",   "target": { "kind": "rail", "rail": "GND" } },
    { "component_id": "amp", "pin_role": "LRCLK", "target": { "kind": "bus",  "bus_id": "i2s0" } },
    { "component_id": "amp", "pin_role": "BCLK",  "target": { "kind": "bus",  "bus_id": "i2s0" } },
    { "component_id": "amp", "pin_role": "DIN",   "target": { "kind": "gpio", "pin": "GPIO32" } },

    { "component_id": "screen", "pin_role": "VCC",       "target": { "kind": "rail", "rail": "3V3" } },
    { "component_id": "screen", "pin_role": "GND",       "target": { "kind": "rail", "rail": "GND" } },
    { "component_id": "screen", "pin_role": "SCK",       "target": { "kind": "bus",  "bus_id": "spi0" } },
    { "component_id": "screen", "pin_role": "MOSI",      "target": { "kind": "bus",  "bus_id": "spi0" } },
    { "component_id": "screen", "pin_role": "CS",        "target": { "kind": "gpio", "pin": "GPIO5"  } },
    { "component_id": "screen", "pin_role": "DC",        "target": { "kind": "gpio", "pin": "GPIO17" } },
    { "component_id": "screen", "pin_role": "RESET",     "target": { "kind": "gpio", "pin": "GPIO22" } },
    { "component_id": "screen", "pin_role": "BACKLIGHT", "target": { "kind": "gpio", "pin": "GPIO16" } },

    { "component_id": "mute",      "pin_role": "OUT", "target": { "kind": "gpio", "pin": "GPIO26" } },
    { "component_id": "backlight", "pin_role": "OUT", "target": { "kind": "gpio", "pin": "GPIO4"  } }
  ],

  "passives": [
    { "id": "c1", "kind": "capacitor", "value": "100nF",
      "between": ["amp.VCC", "GND"],    "purpose": "decoupling amp" },
    { "id": "c2", "kind": "capacitor", "value": "10uF",
      "between": ["amp.VCC", "GND"],    "purpose": "bulk decoupling amp" },
    { "id": "c3", "kind": "capacitor", "value": "100nF",
      "between": ["screen.VCC", "GND"], "purpose": "decoupling display" }
  ],

  "warnings": [
    { "level": "info", "code": "fonts_colors_in_extras",
      "text": "font definitions, color palette, status_led, time, and the system status binary_sensor live in esphome_extras." }
  ],

  "esphome_extras": {
    "logger": {},
    "status_led": { "pin": { "number": "GPIO14", "inverted": true } },
    "binary_sensor": [
      { "platform": "status", "name": "Node Status", "id": "system_status" }
    ],
    "switch": [
      { "platform": "restart", "name": "Esp32 Audio Restart", "id": "reboot" }
    ],
    "time": [
      { "platform": "homeassistant", "id": "esptime" }
    ],
    "color": [
      { "id": "my_red",    "red": "100%", "green": "0%",   "blue": "0%"   },
      { "id": "my_yellow", "red": "100%", "green": "100%", "blue": "0%"   },
      { "id": "my_green",  "red": "0%",   "green": "100%", "blue": "0%"   },
      { "id": "my_blue",   "red": "0%",   "green": "0%",   "blue": "100%" },
      { "id": "my_gray",   "red": "50%",  "green": "50%",  "blue": "50%"  }
    ],
    "font": [
      { "file": "gfonts://Roboto", "id": "arial_48", "size": 48 },
      { "file": "gfonts://Roboto", "id": "arial_24", "size": 24 },
      { "file": "gfonts://Roboto", "id": "arial_12", "size": 12 }
    ]
  },

  "fleet": {
    "device_name": "esp32-audio",
    "tags": ["audio", "garage"],
    "secrets_ref": {
      "wifi_ssid": "!secret wifi_ssid",
      "wifi_password": "!secret wifi_password",
      "api_key": "!secret api_key"
    }
  }
}
